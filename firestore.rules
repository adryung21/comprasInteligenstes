rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isInitialAdminEmail() {
      return signedIn()
        && request.auth.token.email != null
        && request.auth.token.email == "adrian90.2y@gmail.com";
    }

    function isOwner(uid) {
      return signedIn() && request.auth.uid == uid;
    }

    function isAdmin() {
      return signedIn()
        && (
          isInitialAdminEmail()
          || (
            exists(/databases/$(database)/documents/users/$(request.auth.uid))
            && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "admin"
            && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.active == true
          )
        );
    }

    match /users/{uid} {
      allow read: if isOwner(uid) || isAdmin();

      allow create: if isOwner(uid)
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.email == request.auth.token.email
        && (
          (isInitialAdminEmail() && request.resource.data.role == "admin")
          || (!isInitialAdminEmail() && request.resource.data.role == "user")
        );

      allow update: if isAdmin()
        || (
          isOwner(uid)
          && request.resource.data.role == resource.data.role
          && request.resource.data.active == resource.data.active
        );

      allow delete: if isAdmin();

      match /{privateDocument=**} {
        allow read, write: if isOwner(uid) || isAdmin();
      }
    }

    match /products/{productId} {
      allow read: if signedIn();
      allow create, update, delete: if isAdmin();
    }

    match /stores/{storeId} {
      allow read: if signedIn();
      allow create, update, delete: if isAdmin();
    }

    match /categories/{categoryId} {
      allow read: if signedIn();
      allow create, update, delete: if isAdmin();
    }

    match /verifiedPrices/{priceId} {
      allow read: if signedIn();
      allow create, update, delete: if isAdmin();
    }

    match /priceHistory/{historyId} {
      allow read: if signedIn();
      allow create, update, delete: if isAdmin();
    }

    match /submissions/{submissionId} {
      allow create: if signedIn()
        && request.resource.data.createdBy == request.auth.uid
        && request.resource.data.status == "pending";

      allow read: if isAdmin()
        || (signedIn() && resource.data.createdBy == request.auth.uid);

      allow update, delete: if isAdmin();
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
